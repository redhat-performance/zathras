# Kickstart file for Zathras KVM guest unattended install
# Generated by kvm_create role

# Use text mode install
text

# Installation source from ISO
cdrom

# Language and keyboard
lang en_US.UTF-8
keyboard us

# Network configuration - DHCP
network --bootproto=dhcp --device=eth0 --activate --onboot=yes

# Root password (disabled, SSH key only)
rootpw --lock

# SSH key for root access
sshkey --username=root "{{ kvm_guest_pub_key }}"

# Firewall
firewall --enabled --ssh

# SELinux
selinux --enforcing

# Timezone
timezone UTC --utc

# Bootloader
bootloader --location=mbr --append="console=ttyS0,115200n8"

# Disk partitioning - clear all and autopart
clearpart --all --initlabel
autopart --type=lvm

# Packages
%packages
@core
openssh-server
nfs-utils
%end

# Post-install script
%post --log=/root/kickstart-post.log

# Enable and start sshd
systemctl enable sshd
systemctl start sshd

# Configure NFS mount for ISO
mkdir -p /iso_install
echo "{{ kvm_host_ip }}:/iso_install_host /iso_install nfs ro,noauto,x-systemd.automount 0 0" >> /etc/fstab

# Create yum repos pointing to ISO content
cat > /etc/yum.repos.d/iso-baseos.repo << 'BASEOS_EOF'
[iso-baseos]
name=ISO BaseOS
baseurl=file:///iso_install/BaseOS
enabled=1
gpgcheck=0
BASEOS_EOF

cat > /etc/yum.repos.d/iso-appstream.repo << 'APPSTREAM_EOF'
[iso-appstream]
name=ISO AppStream
baseurl=file:///iso_install/AppStream
enabled=1
gpgcheck=0
APPSTREAM_EOF

%end

# Reboot after install
reboot
